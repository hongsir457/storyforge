# Gemini API key (required)
GEMINI_API_KEY=AIza...

# Writer model (used for drafting and revision)
AUTONOVEL_WRITER_MODEL=gemini-3.1-pro-preview

# Judge model (used for evaluation; can be faster/lighter than the writer)
AUTONOVEL_JUDGE_MODEL=gemini-3-flash-preview

# Review model (used in Phase 3b deep review)
AUTONOVEL_REVIEW_MODEL=gemini-3.1-pro-preview

# Gemini API base URL
AUTONOVEL_API_BASE_URL=https://generativelanguage.googleapis.com

# fal.ai key for image generation (Nano Banana 2)
FAL_KEY=your-fal-api-key-here

# ElevenLabs API key for audiobook generation
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
